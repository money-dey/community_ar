# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
# Libraries should not include pubspec.lock, per https://dart.dev/guides/libraries/private-files#pubspeclock.
/pubspec.lock
**/doc/api/
.dart_tool/
.flutter-plugins-dependencies
/build/
/coverage/

# Vendored TensorFlow Lite artifacts (populated by tools/fetch_tflite.sh).
# Large / machine-built — not committed; only the README is tracked.
/third_party/tensorflow-lite/include/
/third_party/tensorflow-lite/lib/

# MediaPipe models — fetched on demand via tools/fetch_models.sh, not committed
native/models/*.tflite
native/models/*.task
native/models/_task_extracted/
